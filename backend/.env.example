# Database
DATABASE_URL=postgresql+asyncpg://research_radar:research_radar_dev@localhost:5432/research_radar
DATABASE_URL_SYNC=postgresql://research_radar:research_radar_dev@localhost:5432/research_radar

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
